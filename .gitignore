.env
.env.*
*.key
secrets/
__pycache__/
*.pyc
.claude/

# Backtest artifacts: large local data cache + transient run logs.
# The cache holds per-ticker yfinance pickles — never commit them.
# Ignore the cache *contents* (not the dir) so the empty folder is preserved.
/data_cache/
backtesting/data_cache/*
!backtesting/data_cache/.gitkeep
*_run.log
*.pkl
